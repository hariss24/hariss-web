<!-- =============================================
     CSS & JS spécifiques à la page À propos
     ============================================= -->
<style>
    @keyframes about-marquee {
        from {
            transform: translateX(0);
        }

        to {
            transform: translateX(-50%);
        }
    }

    .about-marquee {
        animation: about-marquee 35s linear infinite;
        will-change: transform;
    }
</style>

<script>
    (function () {
        var section = document.getElementById('about-obsessions');
        var track = document.getElementById('about-track');
        var progress = document.getElementById('about-progress');
        var steps = document.querySelectorAll('.about-step');

        if (!section || !track || steps.length === 0) return;

        function updateScroll() {
            var rect = section.getBoundingClientRect();
            var vh = window.innerHeight;

            if (rect.top <= 0 && rect.bottom >= vh) {
                var total = rect.height - vh;
                var scrolled = -rect.top;
                var p = Math.max(0, Math.min(1, scrolled / total));
                var maxVw = (steps.length - 1) * 100;

                track.style.transform = 'translate3d(-' + (p * maxVw) + 'vw, 0, 0)';
                if (progress) progress.style.height = (p * 100) + '%';

                var stepFloat = p * (steps.length - 1);
                steps.forEach(function (step, idx) {
                    var dist = Math.abs(stepFloat - idx);
                    var opacity = Math.max(0.1, 1 - dist * 0.9);
                    var scale = Math.max(0.85, 1 - dist * 0.15);
                    step.style.opacity = opacity.toString();
                    var content = step.querySelector('.about-content');
                    if (content) content.style.transform = 'scale(' + scale + ')';
                });

            } else if (rect.top > 0) {
                track.style.transform = 'translate3d(0vw, 0, 0)';
                if (progress) progress.style.height = '0%';
                steps.forEach(function (s, i) {
                    s.style.opacity = i === 0 ? '1' : '0.1';
                    var c = s.querySelector('.about-content');
                    if (c) c.style.transform = i === 0 ? 'scale(1)' : 'scale(0.85)';
                });

            } else {
                var maxVw = (steps.length - 1) * 100;
                track.style.transform = 'translate3d(-' + maxVw + 'vw, 0, 0)';
                if (progress) progress.style.height = '100%';
                steps.forEach(function (s, i) {
                    var isLast = i === steps.length - 1;
                    s.style.opacity = isLast ? '1' : '0.1';
                    var c = s.querySelector('.about-content');
                    if (c) c.style.transform = isLast ? 'scale(1)' : 'scale(0.85)';
                });
            }
        }

        if (typeof lenis !== 'undefined') {
            lenis.on('scroll', updateScroll);
        } else {
            window.addEventListener('scroll', updateScroll, { passive: true });
        }

        updateScroll();
    })();
</script>