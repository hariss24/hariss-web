<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Redirection - Hariss Web</title>
  <!-- Umami Analytics (chargé en synchrone pour tracker avant la redirection) -->
  <script src="https://cloud.umami.is/script.js"
    data-website-id="6531755f-9d60-470d-a21a-3e047cc29f54"></script>
  <!-- Fallback : redirige après 3 secondes si le JS ne fonctionne pas -->
  <meta http-equiv="refresh" content="1; url=/e-commerce">
</head>
<body>
  <p>Redirection en cours...</p>
  <script>
    // Attend 1.5 secondes pour que Umami enregistre la visite, puis redirige
    setTimeout(function() {
      window.location.href = "/e-commerce";
    }, 1000);
  </script>
</body>
</html>
